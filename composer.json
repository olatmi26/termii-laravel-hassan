{
    "name": "hassan/termii-laravel",
    "description": "A modern Laravel 10/11/12+ package for seamless integeration of Termii SMS, Token & Insight API.",
    "keywords": ["laravel", "termii", "sms", "otp", "token", "nigeria", "messaging", "sms-api", "sms-gateway", "sms-provider", "sms-service", "sms-integration", "sms-library", "sms-sdk", "sms-package", "sms-laravel", "sms-laravel-package", "sms-laravel-library", "sms-laravel-sdk", "sms-laravel-package", "sms-laravel-library", "sms-laravel-sdk"],
    "license": "MIT",
    "type": "library",
    "authors": [{
        "name": "Olaiya Taiwo Hassan",
        "email": "olatmybizm@gmail.com",
        "role": "Developer"
    }],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Hassan\\Termii\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hassan\\Termii\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hassan\\Termii\\TermiiServiceProvider"
            ],
            "aliases": {
                "Termii": "Hassan\\Termii\\Facades\\Termii"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}